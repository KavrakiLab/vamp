#pragma once

// AUTO-GENERATED — configured by CMake from build_paths.hh.in.
// Contains the include dirs / cc1 flags / cricket-resources path that match
// the host vamp build, so vamp::jit::LoadOptions defaults are correct without
// the caller re-deriving them.
//
// Build-tree paths are emitted here. An install-time variant should be
// configured by `install(...)` rules — TODO when packaging.

#include <array>
#include <string_view>

namespace vamp::jit::paths
{
    // Headers the JIT'd stub source needs (-I flags).
    inline constexpr std::array<std::string_view, 3> include_dirs = {
        "@VAMP_SRC_IMPL_DIR@",
        "@VAMP_SIMDXORSHIFT_INCLUDE@",
        "@VAMP_CRICKET_INCLUDE_DIR@",
    };

    // System headers (-isystem flags). Suppresses warnings from third-party
    // template-heavy code.
    inline constexpr std::array<std::string_view, 3> system_include_dirs = {
        "@VAMP_EIGEN3_INCLUDE_DIR@",
        "@VAMP_NIGH_INCLUDE_DIR@",
        "@VAMP_PDQSORT_INCLUDE_DIR@",
    };

    // Defines that affect ABI / std layout. Must match vamp's own build.
    inline constexpr std::array<std::string_view, 2> defines = {
        "_GLIBCXX_USE_CXX11_ABI=1",
        "NDEBUG",
    };

    // SIMD / arch + fast-math flags that the JIT'd planner needs to match
    // vamp's static build (vamp/cmake/CompilerSettings.cmake VAMP_FAST_ARGS),
    // plus Clang-specific extras vamp also enables on Clang (we always are),
    // plus -fno-semantic-interposition so Clang inlines across the JIT'd
    // module's internal calls (the module is loaded by ORC as a unit; nothing
    // will interpose its templates).
    inline constexpr std::array<std::string_view, 8> extra_flags = {
        "-march=native",
        "-mavx2",
        "-fno-math-errno",
        "-fno-signed-zeros",
        "-fno-trapping-math",
        "-fno-rounding-math",
        "-ffp-contract=fast",
        "-fassociative-math",
    };

    // cricket's resources/ tree (templates, sample URDFs) is resolved at
    // runtime by asking Python's `cricket.resources_dir()` — that's where the
    // pip-installed wheel actually lives. The vamp.load_robot binding hands
    // the path to DynamicRobot per call.
}  // namespace vamp::jit::paths
