#pragma once

#include <array>
#include <string_view>

namespace vamp::jit::paths
{
    // Headers the JIT'd stub source needs
    inline constexpr std::array<std::string_view, 3> include_dirs = {
        "@VAMP_SRC_IMPL_DIR@",
        "@VAMP_SIMDXORSHIFT_INCLUDE@",
        "@VAMP_CRICKET_INCLUDE_DIR@",
    };

    // System headers 
    inline constexpr std::array<std::string_view, 3> system_include_dirs = {
        "@VAMP_EIGEN3_INCLUDE_DIR@",
        "@VAMP_NIGH_INCLUDE_DIR@",
        "@VAMP_PDQSORT_INCLUDE_DIR@",
    };

    // Defines that affect ABI / std layout, must match vamp's own build
    inline constexpr std::array<std::string_view, 2> defines = {
        "_GLIBCXX_USE_CXX11_ABI=1",
        "NDEBUG",
    };

    // SIMD / arch + fast-math flags that the JIT'd planner needs to match
    // vamp's static build (vamp/cmake/CompilerSettings.cmake VAMP_FAST_ARGS),
    // plus Clang-specific extras vamp also enables on Clang (we always are),
    // plus -fno-semantic-interposition so Clang inlines across the JIT'd
    // module's internal calls (the module is loaded by ORC as a unit; nothing
    // will interpose its templates).
    inline constexpr std::array<std::string_view, 8> extra_flags = {
        "-march=native",
        "-mavx2",
        "-fno-math-errno",
        "-fno-signed-zeros",
        "-fno-trapping-math",
        "-fno-rounding-math",
        "-ffp-contract=fast",
        "-fassociative-math",
    };
}  // namespace vamp::jit::paths
