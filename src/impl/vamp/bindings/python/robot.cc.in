#include <vamp_python_init.hh>

#include <vamp/bindings/python/robot_helper.hh>
#include <vamp/robots/@robot_name@.hh>

void vamp::binding::init_@robot_name@(nanobind::module_ &pymodule)
{
    vamp::binding::init_robot<vamp::robots::@robot_struct@>(pymodule);
}

